# ============================================
# 鹏翔驾校 AI 助手 - 环境变量配置模板
# 部署到云端时，在平台设置以下变量
# ============================================

# 必填 - 豆包 API Key（替换成你自己的）
DOUBAO_API_KEY=ark-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 可选 - 模型选择（默认 doubao）
LLM_PROVIDER=doubao

# 可选 - 模型名（默认 doubao-seed-2-0-mini-260428）
DOUBAO_MODEL_NAME=doubao-seed-2-0-mini-260428

# 可选 - API 地址（默认火山引擎）
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 可选 - 端口（默认 5000，Railway 会自动分配）
PORT=5000